# Copy this file to .env and fill in the values.
# All variables marked REQUIRED will cause the server to refuse startup if missing.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Origins allowed by CORS (comma-separated). In production, set to your actual domain.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Auth — JWT ────────────────────────────────────────────────────────────────
# REQUIRED. Must be at least 32 random characters.
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=replace-with-at-least-32-random-characters

# Access token expiry (default 2h). Refresh token is always 7d.
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Encryption key (AES-256-GCM) ──────────────────────────────────────────────
# REQUIRED. Used to encrypt analysis results at rest and sensitive DB fields.
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
ENCRYPTION_KEY=replace-with-64-hex-chars

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/lawgic.db

# ── Admin access ──────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@example.com

# ── Law data paths ────────────────────────────────────────────────────────────
SPORTS_LAW_PATH=./data/SPORTSS_fixed.json
COMMERCIAL_LAW_159_PATH=./data/law_159_final.json
COMMERCIAL_LAW_95_PATH=./data/law_95_cleaned (1).json

# ── LLM — Groq ────────────────────────────────────────────────────────────────
# REQUIRED. Get from https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── Embeddings — Hugging Face ─────────────────────────────────────────────────
# REQUIRED. Get from https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ── OCR — Google Document AI ──────────────────────────────────────────────────
# REQUIRED. Service account key JSON file path.
# See: https://cloud.google.com/document-ai/docs/setup
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=eu
GCP_DOCAI_PROCESSOR_ID=your-processor-id
OCR_FALLBACK_TESSERACT=false

# ── Vector DB — ChromaDB ─────────────────────────────────────────────────────
# Start: python -m chromadb run --path ./chroma_data --port 8000
#    OR: docker run -p 8000:8000 chromadb/chroma
CHROMA_URL=http://localhost:8000
CHROMA_DATA_PATH=./chroma_data

# ── Email (optional) ──────────────────────────────────────────────────────────
# Used for welcome emails via Gmail SMTP. Server starts fine without these.
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

# ── LawGic feature flags ──────────────────────────────────────────────────────
LAWGIC_ENABLED=true
